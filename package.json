{
  "name": "deploy-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --stream --filter @deploy-management/api --filter @deploy-management/web run dev",
    "dev:api": "pnpm --filter @deploy-management/api dev",
    "dev:api:local-docker": "powershell -ExecutionPolicy Bypass -File scripts/dev-api-local-docker.ps1",
    "dev:web": "pnpm --filter @deploy-management/web dev",
    "deploy": "node scripts/release.mjs ci",
    "deploy:local": "node scripts/release.mjs local",
    "deploy:status": "node scripts/release.mjs status",
    "deploy:logs": "node scripts/release.mjs logs",
    "deploy:watch": "node scripts/release.mjs watch",
    "rollback": "node scripts/release.mjs rollback",
    "deploy:prod": "powershell -ExecutionPolicy Bypass -File scripts/deploy-prod.ps1",
    "deploy:server": "bash scripts/deploy-server.sh",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r --if-present test",
    "migrate:storage:supabase": "node scripts/migrate-json-to-supabase.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
