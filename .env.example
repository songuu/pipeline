# Storage backend. Leave unset/json for local JSON persistence.
DEPLOYMENT_STORAGE=json
DEPLOYMENT_DATA_DIR=.deploy-data

# Local Docker executor registry credentials.
ACR_USERNAME=songyu19960525
ACR_PASSWORD=<local-registry-password>

# Release executors.
# static_site: publish generated package contents to a versioned local directory and switch current.
STATIC_SITE_DEPLOY_ROOT=.codex-tmp/static-sites

# server_package: publish generated package contents to a versioned local directory.
# SERVER_PACKAGE_ACTIVATE_COMMAND runs inside the current release directory after extraction.
SERVER_PACKAGE_DEPLOY_ROOT=.codex-tmp/server-packages
SERVER_PACKAGE_ACTIVATE_COMMAND=
SERVER_PACKAGE_HEALTHCHECK_URL=

# Package upload mirror root for non-container package modes.
# Pipeline packageUpload.endpoint can point to oss://, https://, file:// or a local/static-server path.
PACKAGE_UPLOAD_ROOT=.codex-tmp/package-uploads

# kubernetes_manifest / helm_chart: real cluster deployment.
KUBECONFIG=
KUBECTL_PATH=kubectl
K8S_MANIFEST_PATH=
HELM_PATH=helm
HELM_CHART_PATH=
HELM_TIMEOUT=120s

# Supabase control-plane persistence.
# Never put the service role key into frontend env or client bundles.
# Before switching this to supabase, run supabase/migrations/20260518_domain_storage_tables.sql.
SUPABASE_URL=https://br-ideal-fawn-814db5fc.supabase.aidap-global.cn-beijing.volces.com:443
SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>
SUPABASE_SCHEMA=public

# Control-plane auth. Local dev may leave auth disabled; production must set a token.
CONTROL_PLANE_AUTH_REQUIRED=false
CONTROL_PLANE_API_TOKEN=<server-only-control-plane-token>
CONTROL_PLANE_JWT_SECRET=<optional-hs256-jwt-secret>
CONTROL_PLANE_DEFAULT_ROLE=admin

# Webhook secrets. Provider-specific values override WEBHOOK_SECRET.
WEBHOOK_SECRET=<shared-webhook-secret>
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
GITCODE_WEBHOOK_SECRET=
# Optional per-pipeline secret:
# PIPELINE_WEBHOOK_SECRET_<PIPELINE_ID_WITH_NON_ALNUM_AS_UNDERSCORE>=

# Optional public Supabase config for future frontend-only features.
# The current app does not need direct frontend Supabase access.
NEXT_PUBLIC_SUPABASE_URL=https://br-ideal-fawn-814db5fc.supabase.aidap-global.cn-beijing.volces.com:443
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>
